{
  "name": "nation-of-millions",
  "version": "1.0.0",
  "description": "NationBuilder app that finds people with tags and adds them to paths at specific steps",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "prestart": "npm run build",
    "heroku-prebuild": "echo 'Skipping linting in production - already validated by pre-commit hooks'",
    "test": "jest",
    "prepare": "husky install",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "oauth:setup": "npm run build && node scripts/get-oauth-tokens.js",
    "oauth:save": "npm run build && node scripts/save-refresh-token.js"
  },
  "dependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.15.5",
    "dotenv": "^16.3.0",
    "pg": "^8.16.3",
    "spraypaint": "^0.10.24",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.6.0"
  },
  "keywords": [
    "nationbuilder",
    "automation",
    "tags",
    "paths"
  ],
  "author": "",
  "license": "MIT"
}
