# NationBuilder Configuration
NATIONBUILDER_SLUG=your_nation_slug

# OAuth Configuration (for production)
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret

# Legacy API Token (alternative to OAuth)
# NATIONBUILDER_API_TOKEN=your_api_token_here

# Database Configuration
# Local development (Docker)
DATABASE_URL_LOCAL=postgresql://postgres:password@localhost:5432/nationbuilder_automation

# Production (Heroku Postgres - automatically set by Heroku)
# DATABASE_URL=your_heroku_postgres_url

# OAuth Flow (for token acquisition only)
OAUTH_REDIRECT_URI=https://your-ngrok-url.ngrok.io/callback

# Tag to Path Mappings (format: tag_name|path_slug|step_number)
NB_MAPPING_1=volunteer|volunteer_onboarding|2
NB_MAPPING_2=donor|donor_stewardship|1

# Environment
NODE_ENV=development

# Simulation Mode (default: true for safety)
# Set to 'false' to enable actual API writes
SIMULATION_MODE=true