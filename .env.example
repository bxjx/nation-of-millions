# NationBuilder Configuration
NATIONBUILDER_API_TOKEN=your_api_token_here
NATIONBUILDER_SLUG=your_nation_slug_here

# Tag to Path Mappings (format: TAG_name=path_slug:step_number)
NB_TAG_volunteer=volunteer_onboarding:2
NB_TAG_donor=donor_stewardship:1
NB_TAG_member=member_engagement:3

# Environment
NODE_ENV=production